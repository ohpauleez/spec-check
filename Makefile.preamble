#JVM_G1GC_FLAGS ?= -XX:+UseG1GC
#JVM_SHENGC_FLAGS ?= -XX:+UseShenandoahGC -XX:+UseTransparentHugePages
#JVM_ZGC_FLAGS ?= -XX:+UnlockExperimentalVMOptions -XX:+UseZGC -XX:+UseLargePages -XX:+UseLargePagesInMetaspace -XX:+UseTransparentHugePages


# Issue Warnings
# ---------------------------------------------------------------
ifneq ($(modified_submodules),)
$(warning WARNING - $(modified_submodules))
endif
ifneq ($(not_initd_submodules),)
$(warning WARNING - $(not_initd_submodules))
endif
ifneq ($(conflicted_submodules),)
$(warning WARNING - $(conflicted_submodules))
endif
