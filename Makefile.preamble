# If this project has submodules, check their status
# Issue warnings if there is submodule drift from what is marked in the submodule/git index
git_submodule_status = $(shell git submodule status --recursive)
modified_submodules = $(shell [[ "$(git_submodule_status)" =~ \+([0-9a-f]{5,40}) ]] && echo "You have modified submodules. Consider: git submodule update --recursive")
not_initd_submodules = $(shell [[ "$(git_submodule_status)" =~ -([0-9a-f]{5,40}) ]] && echo "You have submodules that need to be initialized. Consider: git submodule update --init --recursive")
conflicted_submodules = $(shell [[ "$(git_submodule_status)" =~ U([0-9a-f]{5,40}) ]] && echo "You have merge-conflicts in your submodules! Look at status/summary for more details")


# Tools/Executables
# ---------------------------------------------------------------
PY ?= $(shell which python)
PIP ?= $(shell which pip)
JAVA ?= $(shell if [ -d "$(tooling_openjdk_dir)" ]; then echo "$(PWD)/$(tooling_openjdk_dir)/$(java_bin_dir)/java"; else which java; fi)
#JAVAC ?= $(shell if [ -d "$(tooling_openjdk_dir)" ]; then echo "$(PWD)/$(tooling_openjdk_dir)/$(java_bin_dir)/javac"; else which javac; fi)
JAR ?= $(shell if [ -d "$(tooling_openjdk_dir)" ]; then echo "$(PWD)/$(tooling_openjdk_dir)/$(java_bin_dir)/jar"; else which jar; fi)
#MVN ?= $(shell which mvn)
#CLJ ?= JAVA_CMD=$(JAVA) $(shell if [ -d "$(tooling_clojure_dir)" ]; then echo "$(PWD)/$(tooling_clojure_dir)/bin/clj"; else which clj; fi)
#CLOJURE ?= JAVA_CMD=$(JAVA) $(shell if [ -d "$(tooling_clojure_dir)" ]; then echo "$(PWD)/$(tooling_clojure_dir)/bin/clojure"; else which clojure; fi)
NPM ?= $(shell which npm)

# Vars/Settings
# ---------------------------------------------------------------

# This is a var you can use for JAVA_HOME if needed for tooling/targets
JHOME =$(shell if [ -d "$(tooling_openjdk_dir)" ]; then echo "$(PWD)/$(tooling_openjdk_dir)/$(jhome_slug)"; else echo $(JAVA_HOME); fi)

## Technically, we can run the $(shell ...) in the targets we need, but this lets you set CP per make invocation
